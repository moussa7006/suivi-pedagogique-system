# Exemple de configuration locale backend EduTrack
# À adapter puis exporter dans votre shell ou intégrer dans votre environnement de déploiement.

SERVER_PORT=8099

DB_URL=jdbc:postgresql://localhost:5432/db_suivipedago
DB_USERNAME=postgres
DB_PASSWORD=change-me

JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100,https://*.relais.dev,http://*.relais.dev

APP_SEED_ADMIN_ENABLED=true
APP_SEED_ADMIN_RESET_EXISTING=true
APP_SEED_ADMIN_EMAIL=admin@edutrack.local
APP_SEED_ADMIN_PASSWORD=ChangeMe123456!
APP_SEED_ADMIN_NOM=ADMIN
APP_SEED_ADMIN_PRENOM=EduTrack
APP_SEED_ADMIN_MATRICULE=2026-ADM-001
APP_SEED_ADMIN_TELEPHONE=
APP_SEED_ADMIN_ADRESSE=

# Minimum 32 octets. Remplacer impérativement en production.
APP_JWT_SECRET=replace_with_a_strong_32_bytes_minimum_secret
APP_JWT_EXPIRATION_MS=86400000
